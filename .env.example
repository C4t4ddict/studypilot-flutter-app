SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional MySQL fallback (keep Supabase config as-is)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=guiculum
MYSQL_USER=guiculum_user
MYSQL_PASSWORD=guiculum123!

# PlannerService source switch
USE_MYSQL_API=false
MYSQL_API_BASE_URL=http://127.0.0.1:8100

# Google Calendar OAuth (optional)
# Web/iOS client id (Google Cloud OAuth Client)
GOOGLE_CLIENT_ID=
# Web server client id (optional but recommended)
GOOGLE_SERVER_CLIENT_ID=
